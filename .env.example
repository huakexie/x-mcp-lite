# Twitter credentials (required for auto-login; not needed if you only use
# cookie_json or cookie_file args of the get_cookie tool)
TWITTER_USERNAME=
TWITTER_EMAIL=
TWITTER_PASSWORD=

# Optional: path to cookies file. Defaults to ~/.x-mcp/cookies.json
# Set this on both the login machine and the deployment machine.
# X_MCP_COOKIES_PATH=/path/to/cookies.json

# Optional: custom user agent
# USER_AGENT=Mozilla/5.0 ...

# Optional: CAPTCHA solver API key (only needed if you hit Arkose challenges)
# CAPSOLVER_API_KEY=
